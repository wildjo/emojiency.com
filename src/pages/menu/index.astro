---
import Base from '../../layouts/Base.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base title="Menu — Emojiency">
  <div class="content-area">
    <div class="content-hamburger-menu">
      <a class="menu-link" href="https://duckduckgo.com/?q=site%3Aemojiency.com" target="_blank" rel="noopener">
        search (via DuckDuckGo)
      </a>
      <a class="menu-link" href={`${base}/menu/about/`}>
        about Jonnie
      </a>
      <a class="menu-link" href={`${base}/menu/recommended/`}>
        recommended
      </a>
    </div>
  </div>
</Base>
