---
import Base from '../../layouts/Base.astro';
import Recommendations from '../../components/Recommendations.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base title="Recommended — Emojiency" section="articles">
  <div class="content-area">
    <div class="content-articles-toc recommendations-page">
      <Recommendations />
      <a class="archive-link" href={`${base}/articles/archive/`}>Browse the complete article archive →</a>
    </div>
  </div>
</Base>
