---
import Base from '../layouts/Base.astro';
import Recommendations from '../components/Recommendations.astro';
import NewsFeed from '../components/NewsFeed.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base title="Emojiency" section="home">
  <div class="content-area home-grid">
    <div class="content-home-main">
      <div class="static-logo">
        <img src={`${base}/images/splash/emojiency-splash.png`} alt="Emojiency" />
      </div>
      <Recommendations compact />
      <a class="archive-link" href={`${base}/articles/archive/`}>Browse the complete article archive →</a>
    </div>

    <NewsFeed />
  </div>
</Base>
