---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allArticles = (await getCollection('articles'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 10);
---

<Base title="Articles — Emojiency">
  <div class="content-area">
    <div class="content-articles-toc">
      {allArticles.map(article => (
        <a class="toc-entry" href={`/articles/${article.id}/`}>
          {article.data.hero && (
            <img src={`/images/articles/${article.data.hero}`} alt={article.data.title}
              style="width: 100%; max-height: 200px; object-fit: cover; margin-bottom: 12px;" />
          )}
          <div class="toc-entry-title">{article.data.title}</div>
          <div class="toc-entry-summary">{article.data.summary}</div>
          <div class="toc-entry-date">
            {article.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </div>
        </a>
      ))}
    </div>
  </div>
</Base>
