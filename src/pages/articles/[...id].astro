---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map(article => ({
    params: { id: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base title={`${article.data.title} — Emojiency`}>
  <div class="content-area">
    <div class="content-article-detail">
      <div class="article-header">
        <h1 class="article-title">{article.data.title}</h1>
        <div class="article-date">
          {article.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </div>
      </div>

      {article.data.hero && (
        <img
          class="article-hero"
          src={`${base}/images/articles/${article.data.hero}`}
          alt={article.data.heroCaption || article.data.title}
          onclick={`openLightbox('${base}/images/articles/${article.data.hero}', '${(article.data.heroCaption || '').replace(/'/g, "\\'")}')`}
        />
      )}

      <div class="article-body">
        <Content />
      </div>
    </div>
  </div>
</Base>
