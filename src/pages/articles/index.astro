---
import Base from '../../layouts/Base.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { published } from '../../lib/content';

const articles = published(await getCollection('posts'))
  .filter((post) => post.data.kind === 'article');
---

<Base title="Articles — Emojiency" section="articles">
  <div class="content-area">
    <div class="content-articles-toc">
      <div class="section-heading">
        <h1>Articles</h1>
        <p>{articles.length} pieces, newest first.</p>
      </div>
      {articles.map((article) => (
        <PostCard post={article} variant="archive" />
      ))}
    </div>
  </div>
</Base>
