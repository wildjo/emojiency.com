---
import Base from '../../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { published } from '../../../lib/content';
import PostCard from '../../../components/PostCard.astro';

export async function getStaticPaths({ paginate }) {
  const articles = published(await getCollection('posts'))
    .filter((post) => post.data.kind === 'article');
  return paginate(articles, { pageSize: 30 });
}

const { page } = Astro.props;
---

<Base title={`Article archive${page.currentPage > 1 ? `, page ${page.currentPage}` : ''} — Emojiency`} section="articles">
  <div class="content-area">
    <div class="content-articles-toc">
      <div class="section-heading">
        <h1>Article archive</h1>
        <p>{page.total} pieces, newest first.</p>
      </div>
      {page.data.map((article) => (
        <PostCard post={article} variant="archive" />
      ))}
      <nav class="pagination" aria-label="Article archive pages">
        {page.url.prev && <a href={page.url.prev}>← Newer</a>}
        <span>Page {page.currentPage} of {page.lastPage}</span>
        {page.url.next && <a href={page.url.next}>Older →</a>}
      </nav>
    </div>
  </div>
</Base>
