---
import type { GalleryImage } from '../lib/content';

interface Props {
  images: GalleryImage[];
}

const { images } = Astro.props;
---

{images.length > 0 && (
  <div class="slideshow" data-carousel data-lightbox-gallery data-images={JSON.stringify(images)}>
    <div class="slideshow-track" data-carousel-track>
      {images.map((image, index) => (
        <button
          type="button"
          class="slideshow-slide"
          data-gallery-index={index}
          aria-label={`Open image ${index + 1} of ${images.length}`}
        >
          <img src={image.src} alt={image.caption} loading={index === 0 ? 'eager' : 'lazy'} />
        </button>
      ))}
    </div>
    {images.length > 1 && (
      <div class="slideshow-dots" aria-label="Choose gallery image">
        {images.map((_, index) => (
          <button
            type="button"
            class:list={['slideshow-dot', { active: index === 0 }]}
            data-carousel-dot={index}
            aria-label={`Show image ${index + 1}`}
          />
        ))}
      </div>
    )}
  </div>
)}
