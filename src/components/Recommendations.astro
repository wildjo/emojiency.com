---
import { getCollection } from 'astro:content';
import { published } from '../lib/content';
import PostCard from './PostCard.astro';

interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
const recommendationIds = [
  'whos-assimilating-whom',
  'math-is-hard',
  'morality-star-wars-and-obi-wan-kenobi',
  'slave-morality',
  'the-politics-of-tom-clancys-the-division-2',
  'start-em-young-embrace-the-violence-of-video-games',
  'bullies-rule-the-world-only-because-we-demand-it',
  'morality-monday-mash',
  'the-terrible-flag-of-my-people',
  'quantum-rocks',
  'artificial-intelligence-needs-our-help-lets-design-a-user-experience-for-ai',
  'what-the-autopsy-revealed',
  'i-wrote-vacuum-from-the-onion-november-15-1988',
  '8161',
  'social-anxiety',
  'farewell-worthy-adversary',
  'dont-force-feelings-feel-them-then-let-them-go',
  'my-cyberpunk-future',
  'international-noobs-day',
  'rebirth-and-resurrection-as-metaphor',
  'doing-it-right',
  'johanna-wilder-alternative-newspaper-mogul-shuffles-off-mortal-coil',
  'battling-back',
];
const postById = new Map(
  published(await getCollection('posts'))
    .map((post) => [post.id, post]),
);
const recommendations = recommendationIds
  .map((id) => postById.get(id))
  .filter((post) => post !== undefined);
---

<section class:list={['recommendations', { 'recommendations-compact': compact }]}>
  <div class="section-heading">
    <h1>Recommended</h1>
    <p>Curated picks from recent work and the archives.</p>
  </div>
  <div class="recommendation-list">
    {recommendations.map((post) => (
      <PostCard post={post} variant="recommendation" />
    ))}
  </div>
</section>
